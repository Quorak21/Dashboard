+import { TestBed } from '@angular/core/testing';
+import { of } from 'rxjs';
+import { vi, type Mock } from 'vitest';
+
+import { Infr } from './infr';
+import { DashboardApiService } from '../../../core/services/dashboard-api.service';
+import type { AssetDto } from '../../../core/models';
+
+describe('Infr', () => {
+  let getAssetSpy: Mock;
+
+  const mockAsset: AssetDto = {
+    assetId: 'infr',
+    symbol: 'INFR',
+    displayName: 'iShares Global Infrastructure',
+    type: 'ETF',
+    currency: 'USD',
+    currentPrice: 24.50,
+    marketCap: 2800,
+    priceChangePercentage24h: -0.45,
+    totalVolume: 120,
+    lastRefresh: Date.UTC(2026, 5, 2, 8, 0, 0),
+    priceSource: 'FMP',
+    marketStatus: 'OPEN',
+    historyPrices: [1, 2],
+    historyDays: [10, 20],
+    livePrices: [3, 4],
+    liveDays: [30, 40],
+    dividends: null,
+    fundamentals: {
+      updatedAt: '2025-05-31',
+      source: 'iShares Factsheet',
+      stale: false,
+      metrics: {
+        'management-fee': '0.65%'
+      },
+      topHoldings: [
+        { name: 'NextEra Energy', weightPercent: 6.1 }
+      ],
+      sectorWeights: [
+        { sector: 'Utilities', weightPercent: 61.2 }
+      ]
+    },
+  };
+
+  beforeAll(() => {
+    (globalThis as any).ResizeObserver = class {
+      observe() {}
+      unobserve() {}
+      disconnect() {}
+    };
+  });
+
+  beforeEach(async () => {
+    getAssetSpy = vi.fn().mockReturnValue(of(mockAsset));
+
+    await TestBed.configureTestingModule({
+      imports: [Infr],
+      providers: [
+        {
+          provide: DashboardApiService,
+          useValue: { getAsset: getAssetSpy },
+        },
+      ],
+    }).compileComponents();
+  });
+
+  it('should compile and render the AssetPage component with assetId infr', async () => {
+    const fixture = TestBed.createComponent(Infr);
+    fixture.detectChanges();
+
+    expect(getAssetSpy).toHaveBeenCalledWith('infr');
+    const element: HTMLElement = fixture.nativeElement;
+    const assetPageEl = element.querySelector('app-asset-page');
+    expect(assetPageEl).toBeTruthy();
+    fixture.destroy();
+  });
+});
