+<div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col flex-grow gap-8">
+  @if (loading()) {
+    <div class="flex items-center justify-center py-20">
+      <span class="text-copper-400 text-lg font-medium animate-pulse">Chargement des données...</span>
+    </div>
+  } @else if (!data()) {
+    <div class="flex items-center justify-center py-20">
+      <span class="text-red-400 text-lg font-medium">Impossible de charger les données de l'actif.</span>
+    </div>
+  } @else {
+    <!-- Price freshness badge + main card -->
+    <div class="flex flex-col gap-4">
+      <div class="flex justify-start">
+        <app-price-freshness-badge
