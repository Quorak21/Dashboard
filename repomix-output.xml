<file path="frontend/src/app/features/crypto/services/format-dates.ts">
export function formatTime(timestamp: number | undefined | null): string {
    if (!timestamp) return '--:--';

    const date = new Date(timestamp);

    // On récupère les heures et minutes et on s'assure d'avoir 2 chiffres (ex: 09:05)
    const hours = date.getHours().toString().padStart(2, '0');
    const minutes = date.getMinutes().toString().padStart(2, '0');

    return `${hours}:${minutes}`;
}
</file>

<file path="frontend/src/app/features/crypto/services/format-number.ts">
export function formatNumber(num: number | undefined | null): string {
    if (num === null || num === undefined) return '0';

    const absNum = Math.abs(num);

    if (absNum >= 1.0e+9) {
        return (num / 1.0e+9).toFixed(2).replace(/\.00$/, '') + 'B';
    }
    if (absNum >= 1.0e+6) {
        return (num / 1.0e+6).toFixed(2).replace(/\.00$/, '') + 'M';
    }
    if (absNum >= 1.0e+3) {
        return (num / 1.0e+3).toFixed(2).replace(/\.00$/, '') + 'K';
    }


    return num.toFixed(2).replace(/\.00$/, '');
}
</file>

